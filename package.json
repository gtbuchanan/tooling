{
  "scripts": {
    "gtb": "node --experimental-strip-types packages/cli/src/main.ts",
    "prepare": "pnpm run gtb prepare",
    "build:ci": "turbo run check compile:ts && pnpm run gtb pack",
    "test:e2e": "pnpm run gtb test:vitest:e2e",
    "test:slow": "pnpm run gtb test:vitest:slow",
    "check": "turbo run check",
    "build": "turbo run check compile:ts test:vitest:slow && pnpm run gtb pack && pnpm run test:e2e"
  },
  "name": "tooling-root",
  "private": true,
  "homepage": "https://github.com/gtbuchanan/tooling",
  "bugs": "https://github.com/gtbuchanan/tooling/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtbuchanan/tooling.git"
  },
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@gtbuchanan/cli": "workspace:*",
    "@gtbuchanan/eslint-config": "workspace:*",
    "@gtbuchanan/oxfmt-config": "workspace:*",
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/tsconfig": "workspace:*",
    "@gtbuchanan/vitest-config": "workspace:*",
    "@j178/prek": "catalog:",
    "@tsconfig/strictest": "catalog:",
    "@types/cross-spawn": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "console-fail-test": "catalog:",
    "cross-spawn": "catalog:",
    "eslint": "catalog:",
    "find-up-simple": "catalog:",
    "jiti": "catalog:",
    "markdownlint-cli2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.17"
  },
  "packageManager": "pnpm@10.32.1"
}
