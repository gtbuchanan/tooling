{
  "name": "tooling-root",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtbuchanan/tooling.git"
  },
  "bugs": "https://github.com/gtbuchanan/tooling/issues",
  "homepage": "https://github.com/gtbuchanan/tooling",
  "engines": {
    "node": ">=22.16"
  },
  "scripts": {
    "build": "pnpm compile && concurrently -g pnpm:lint pnpm:test pnpm:prepare-publish && pnpm run pack && pnpm test:e2e",
    "changeset": "changeset",
    "check": "pnpm compile && concurrently -g pnpm:lint pnpm:test",
    "compile": "tsc -b",
    "lint": "concurrently -g pnpm:lint:oxlint pnpm:lint:eslint",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:oxlint": "oxlint",
    "pack": "node --experimental-strip-types scripts/pack-all.ts",
    "prepare-publish": "node --experimental-strip-types scripts/prepare-publish.ts",
    "release": "pnpm build && changeset publish",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@gtbuchanan/eslint-config": "workspace:*",
    "@gtbuchanan/oxfmt-config": "workspace:*",
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/tsconfig": "workspace:*",
    "@gtbuchanan/vitest-config": "workspace:*",
    "@tsconfig/strictest": "catalog:",
    "@types/cross-spawn": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "concurrently": "catalog:",
    "cross-spawn": "catalog:",
    "eslint": "catalog:",
    "find-up-simple": "catalog:",
    "jiti": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "vitest": "catalog:"
  }
}
