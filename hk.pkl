amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

// Lockfiles are machine-generated; keep the file-hygiene hooks off them.
local lockfiles = Regex(#"[-.]lock(\.|$)"#)

local renovateCheck = "renovate-config-validator --strict {{files}}"

// POSIX gitlink (submodule, mode 160000) guard; the cmd.exe variant lives
// inline on the Windows branch below.
local gitlinkGuardPosix = "test -z \"$(git ls-files --stage | grep -E '^160000 ' || true)\""

// `hk:all` exports HK_BATCH=1 to batch file-heavy steps for a full-repo run,
// keeping hk's per-step command under Windows' cmd.exe 8191-char limit
// (jdx/hk discussion #971: https://github.com/jdx/hk/discussions/971). Off by
// default so commits invoke each linter once — batching runs them per chunk,
// which is slower on the small changesets commits and PRs produce.
local batchFiles = (read?("env:HK_BATCH") ?? "0") == "1"

local allSteps = new Mapping<String, Step> {
    ["check-added-large-files"] = (Builtins.check_added_large_files) { exclude = lockfiles; batch = batchFiles }
    ["end-of-file-fixer"] = (Builtins.newlines) { exclude = lockfiles; batch = batchFiles }
    ["fix-byte-order-marker"] = (Builtins.byte_order_marker) { exclude = lockfiles; batch = batchFiles }
    ["trailing-whitespace"] = (Builtins.trailing_whitespace) { exclude = lockfiles; batch = batchFiles }
    ["actionlint"] = Builtins.actionlint

    // No hk builtin for this, so check the index directly. No `glob`, so
    // it runs unconditionally and fails when the index contains a
    // submodule (mode 160000) entry.
    ["forbid-submodules"] {
        check = new Script {
            windows = "git ls-files -s | findstr /b /c:\"160000 \" >nul && exit /b 1 || exit /b 0"
            linux = gitlinkGuardPosix
            macos = gitlinkGuardPosix
            other = gitlinkGuardPosix
        }
    }

    // renovate-config-validator ships only inside the `renovate` npm
    // package (pinned via mise `npm:renovate`); resolved on PATH by
    // `hk install --mise`. One step per validated config file.
    ["renovate-preset"] {
        glob = "default.json"
        check = renovateCheck
    }
    ["renovate-config"] {
        glob = ".github/renovate.json"
        check = renovateCheck
    }

    // Config packages aren't published yet, so eslint runs against the
    // repo's own node_modules; consumers point this at their installed
    // @gtbuchanan/eslint-config.
    ["eslint"] {
        batch = batchFiles
        check = "pnpm exec eslint --max-warnings=0 --no-warn-ignored {{files}}"
        fix = "pnpm exec eslint --fix --max-warnings=0 --no-warn-ignored {{files}}"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps {
            ...allSteps
            // Commit-time guard only: it needs a branch name, so it errors on
            // CI's detached HEAD and is irrelevant to `hk check`/`hk fix`.
            ["no-commit-to-branch"] = Builtins.no_commit_to_branch
        }
    }
    ["check"] {
        steps { ...allSteps }
    }
    ["fix"] {
        fix = true
        steps { ...allSteps }
    }
}
