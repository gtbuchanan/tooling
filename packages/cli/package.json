{
  "name": "@gtbuchanan/cli",
  "version": "0.2.1",
  "description": "Shared build CLI",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./eslint-sarif-formatter": "./src/lib/eslint-sarif-formatter.ts"
  },
  "bin": {
    "gtb": "./dist/source/bin/gtb.js"
  },
  "scripts": {
    "compile:skills": "pnpm run gtb task compile:skills",
    "compile:ts": "pnpm run gtb task compile:ts",
    "coverage:codecov:upload": "pnpm run gtb task coverage:codecov:upload",
    "coverage:vitest:merge": "pnpm run gtb task coverage:vitest:merge",
    "deploy:skills": "pnpm run gtb task deploy:skills",
    "gtb": "node --experimental-strip-types ../../packages/cli/bin/gtb.ts",
    "lint:eslint": "pnpm run gtb task lint:eslint",
    "pack:npm": "pnpm run gtb task pack:npm",
    "test:vitest:e2e": "pnpm run gtb task test:vitest:e2e",
    "test:vitest:fast": "pnpm run gtb task test:vitest:fast",
    "test:vitest:slow": "pnpm run gtb task test:vitest:slow",
    "typecheck:ts": "pnpm run gtb task typecheck:ts"
  },
  "dependencies": {
    "@microsoft/eslint-formatter-sarif": "catalog:",
    "@microsoft/sarif-multitool": "catalog:",
    "citty": "catalog:",
    "cross-spawn": "catalog:",
    "find-up-simple": "catalog:",
    "get-tsconfig": "catalog:",
    "hosted-git-info": "catalog:",
    "smol-toml": "catalog:",
    "valibot": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "@gtbuchanan/eslint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*",
    "@gtbuchanan/vitest-config": "workspace:*",
    "@types/cross-spawn": "catalog:",
    "@types/hosted-git-info": "catalog:"
  },
  "peerDependencies": {
    "skills": "^1.5.1",
    "skills-npm": "^1.1.1",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "skills-npm": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "bin": {
      "gtb": "./bin/gtb.js"
    },
    "directory": "dist/source",
    "exports": {
      ".": "./src/index.js",
      "./eslint-sarif-formatter": "./src/lib/eslint-sarif-formatter.js"
    },
    "imports": {
      "#src/*.ts": "./src/*.js"
    },
    "linkDirectory": false
  }
}
