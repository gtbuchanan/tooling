{
  "name": "@gtbuchanan/cli",
  "version": "0.1.0",
  "description": "Shared build CLI",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "gtb": "./dist/source/bin/gtb.js"
  },
  "scripts": {
    "compile:ts": "pnpm run gtb compile:ts",
    "coverage:codecov:upload": "pnpm run gtb coverage:codecov:upload",
    "coverage:vitest:merge": "pnpm run gtb coverage:vitest:merge",
    "gtb": "node --experimental-strip-types ../../packages/cli/bin/gtb.ts",
    "lint:eslint": "pnpm run gtb lint:eslint",
    "pack:npm": "pnpm run gtb pack:npm",
    "test:vitest:e2e": "pnpm run gtb test:vitest:e2e",
    "test:vitest:fast": "pnpm run gtb test:vitest:fast",
    "test:vitest:slow": "pnpm run gtb test:vitest:slow",
    "typecheck:ts": "pnpm run gtb typecheck:ts"
  },
  "dependencies": {
    "cross-spawn": "catalog:",
    "find-up-simple": "catalog:",
    "valibot": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/eslint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*",
    "@gtbuchanan/vitest-config": "workspace:*",
    "@types/cross-spawn": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=22.17"
  },
  "publishConfig": {
    "bin": {
      "gtb": "./bin/gtb.js"
    },
    "directory": "dist/source",
    "exports": {
      ".": "./src/index.js"
    },
    "imports": {
      "#src/*.ts": "./src/*.js"
    },
    "linkDirectory": false
  }
}
