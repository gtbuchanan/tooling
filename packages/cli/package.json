{
  "scripts": {
    "compile:ts": "tsc -b src",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:oxlint": "oxlint -c oxlint.config.ts",
    "test:vitest:fast": "vitest run --tags-filter=!slow",
    "test:vitest:slow": "vitest run --tags-filter=slow --pass-with-no-tests",
    "typecheck:ts": "tsc --noEmit"
  },
  "name": "@gtbuchanan/cli",
  "version": "0.1.0",
  "description": "Shared build CLI",
  "bin": {
    "gtb": "./dist/source/main.js"
  },
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "bin": {
      "gtb": "./main.js"
    },
    "directory": "dist/source",
    "exports": {
      ".": "./index.js"
    },
    "linkDirectory": false
  },
  "dependencies": {
    "cross-spawn": "catalog:",
    "find-up-simple": "catalog:",
    "valibot": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*",
    "@gtbuchanan/vitest-config": "workspace:*",
    "@types/cross-spawn": "catalog:"
  },
  "engines": {
    "node": ">=22.17"
  }
}
