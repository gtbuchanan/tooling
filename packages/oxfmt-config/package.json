{
  "devDependencies": {
    "@gtbuchanan/eslint-config": "workspace:*",
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*",
    "@gtbuchanan/vitest-config": "workspace:*"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./index.js"
    },
    "linkDirectory": false
  },
  "scripts": {
    "compile:ts": "gtb compile:ts",
    "lint:eslint": "gtb lint:eslint",
    "lint:oxlint": "gtb lint:oxlint",
    "test:vitest:fast": "gtb test:vitest:fast",
    "test:vitest:slow": "gtb test:vitest:slow",
    "typecheck:ts": "gtb typecheck:ts",
    "gtb": "node --experimental-strip-types ../../packages/cli/bin/gtb.ts"
  },
  "name": "@gtbuchanan/oxfmt-config",
  "version": "0.1.0",
  "description": "Shared oxfmt configuration",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "peerDependencies": {
    "oxfmt": ">=0.43.0"
  },
  "engines": {
    "node": ">=22.17"
  }
}
