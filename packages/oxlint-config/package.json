{
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "eslint-plugin-import-x": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/test-utils": "workspace:*"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./index.js"
    },
    "linkDirectory": false
  },
  "scripts": {
    "compile:ts": "gtb compile:ts",
    "lint:eslint": "gtb lint:eslint",
    "lint:oxlint": "gtb lint:oxlint",
    "test:vitest:fast": "gtb test:vitest:fast",
    "test:vitest:slow": "gtb test:vitest:slow",
    "typecheck:ts": "gtb typecheck:ts",
    "gtb": "node --experimental-strip-types ../../packages/cli/bin/gtb.ts"
  },
  "name": "@gtbuchanan/oxlint-config",
  "version": "0.1.0",
  "description": "Shared oxlint configuration",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "peerDependencies": {
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": ">=0.19.0"
  },
  "peerDependenciesMeta": {
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.17"
  }
}
