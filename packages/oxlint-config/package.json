{
  "scripts": {
    "compile:ts": "tsc -b src",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:oxlint": "oxlint -c oxlint.config.ts",
    "test:vitest:fast": "vitest run --tags-filter=!slow",
    "test:vitest:slow": "vitest run --tags-filter=slow --pass-with-no-tests",
    "typecheck:ts": "tsc --noEmit"
  },
  "name": "@gtbuchanan/oxlint-config",
  "version": "0.1.0",
  "description": "Shared oxlint configuration",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./index.js"
    },
    "linkDirectory": false
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "eslint-plugin-import-x": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/test-utils": "workspace:*"
  },
  "peerDependencies": {
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": ">=0.19.0"
  },
  "peerDependenciesMeta": {
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.17"
  }
}
