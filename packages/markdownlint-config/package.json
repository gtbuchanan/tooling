{
  "scripts": {
    "compile:ts": "tsc -b src",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:oxlint": "oxlint -c oxlint.config.ts",
    "typecheck:ts": "tsc --noEmit"
  },
  "name": "@gtbuchanan/markdownlint-config",
  "version": "0.1.0",
  "description": "Shared markdownlint configuration",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./index.mjs"
    },
    "linkDirectory": false
  },
  "dependencies": {
    "markdownlint": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/eslint-config": "workspace:*",
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*"
  },
  "engines": {
    "node": ">=22.17"
  }
}
