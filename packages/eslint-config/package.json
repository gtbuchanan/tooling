{
  "name": "@gtbuchanan/eslint-config",
  "version": "0.0.0",
  "description": "Shared ESLint configuration",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./index.js"
    },
    "linkDirectory": false
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:",
    "@eslint/json": "catalog:",
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-n": "catalog:",
    "eslint-plugin-only-warn": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "eslint-plugin-pnpm": "catalog:",
    "eslint-plugin-yml": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/test-utils": "workspace:*"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "engines": {
    "node": ">=22.16"
  }
}
