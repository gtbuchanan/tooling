{
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "catalog:",
    "@eslint/json": "catalog:",
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@stylistic/eslint-plugin": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-n": "catalog:",
    "eslint-plugin-only-warn": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "eslint-plugin-pnpm": "catalog:",
    "eslint-plugin-yml": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*",
    "@gtbuchanan/vitest-config": "workspace:*"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./index.js"
    },
    "linkDirectory": false
  },
  "scripts": {
    "compile:ts": "gtb compile:ts",
    "lint:eslint": "gtb lint:eslint",
    "lint:oxlint": "gtb lint:oxlint",
    "test:vitest:fast": "gtb test:vitest:fast",
    "test:vitest:slow": "gtb test:vitest:slow",
    "typecheck:ts": "gtb typecheck:ts",
    "gtb": "node --experimental-strip-types ../../packages/cli/bin/gtb.ts"
  },
  "name": "@gtbuchanan/eslint-config",
  "version": "0.1.0",
  "description": "Shared ESLint configuration",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "engines": {
    "node": ">=22.17"
  }
}
