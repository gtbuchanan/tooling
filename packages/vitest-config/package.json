{
  "name": "@gtbuchanan/vitest-config",
  "version": "0.1.0",
  "description": "Shared Vitest configuration",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./configure": "./src/configure.ts",
    "./configure-e2e": "./src/configure-e2e.ts",
    "./setup": "./src/setup.ts",
    "./console-fail-test": "./src/console-fail-test.ts"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./src/index.js",
      "./configure": "./src/configure.js",
      "./configure-e2e": "./src/configure-e2e.js",
      "./setup": "./src/setup.js",
      "./console-fail-test": "./src/console-fail-test.js"
    },
    "linkDirectory": false
  },
  "scripts": {
    "compile:ts": "pnpm run gtb compile:ts",
    "pack:npm": "pnpm run gtb pack:npm",
    "lint:eslint": "pnpm run gtb lint:eslint",
    "lint:oxlint": "pnpm run gtb lint:oxlint",
    "test:vitest:fast": "pnpm run gtb test:vitest:fast",
    "test:vitest:slow": "pnpm run gtb test:vitest:slow",
    "coverage:vitest:merge": "pnpm run gtb coverage:vitest:merge",
    "typecheck:ts": "pnpm run gtb typecheck:ts",
    "gtb": "node --experimental-strip-types ../../packages/cli/bin/gtb.ts",
    "coverage:codecov:upload": "pnpm run gtb coverage:codecov:upload"
  },
  "dependencies": {
    "console-fail-test": "catalog:",
    "find-up-simple": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.17"
  }
}
