{
  "name": "@gtbuchanan/vitest-config",
  "version": "0.1.0",
  "description": "Shared Vitest configuration",
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./configure": "./src/configure.ts",
    "./configure-e2e": "./src/configure-e2e.ts",
    "./setup": "./src/setup.ts",
    "./console-fail-test": "./src/console-fail-test.ts"
  },
  "publishConfig": {
    "directory": "dist/source",
    "exports": {
      ".": "./index.js",
      "./configure": "./configure.js",
      "./configure-e2e": "./configure-e2e.js",
      "./setup": "./setup.js",
      "./console-fail-test": "./console-fail-test.js"
    },
    "linkDirectory": false
  },
  "dependencies": {
    "console-fail-test": "catalog:"
  },
  "devDependencies": {
    "@gtbuchanan/test-utils": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.16"
  }
}
