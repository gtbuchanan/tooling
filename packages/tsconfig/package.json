{
  "name": "@gtbuchanan/tsconfig",
  "version": "0.1.0",
  "description": "Shared TypeScript configuration",
  "files": [
    "node.json"
  ],
  "type": "module",
  "exports": {
    "./node.json": "./node.json"
  },
  "publishConfig": {
    "directory": "dist/source",
