{
  "scripts": {
    "compile": "node --experimental-strip-types scripts/flatten.ts",
    "lint:eslint": "eslint --max-warnings=0",
    "lint:oxlint": "oxlint -c oxlint.config.ts",
    "typecheck:ts": "tsc --noEmit"
  },
  "name": "@gtbuchanan/tsconfig",
  "version": "0.1.0",
  "description": "Shared TypeScript configuration",
  "files": [
    "node.json"
  ],
  "type": "module",
  "exports": {
    "./node.json": "./node.json"
  },
  "publishConfig": {
    "directory": "dist/source",
    "linkDirectory": false
  },
  "devDependencies": {
    "@gtbuchanan/oxlint-config": "workspace:*",
    "@gtbuchanan/test-utils": "workspace:*",
    "@tsconfig/strictest": "catalog:"
  },
  "engines": {
    "node": ">=22.17"
  }
}
