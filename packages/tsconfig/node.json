{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowJs": true,
    "lib": [
      "ES2024"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "target": "ES2024",
    "types": [
      "node"
    ]
  },
  "extends": [
    "@tsconfig/strictest/tsconfig.json"
  ]
}
