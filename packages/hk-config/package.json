{
  "name": "@gtbuchanan/hk-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared hk pre-commit preset (Pkl)",
  "type": "module",
  "scripts": {
    "gtb": "node --experimental-strip-types ../../packages/cli/bin/gtb.ts",
    "lint:eslint": "pnpm run gtb task lint:eslint",
    "pack:pkl": "pnpm run gtb task pack:pkl",
    "typecheck:pkl": "pnpm run gtb task typecheck:pkl",
    "typecheck:ts": "pnpm run gtb task typecheck:ts"
  },
  "devDependencies": {
    "@gtbuchanan/eslint-config": "workspace:*",
    "@gtbuchanan/tsconfig": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
