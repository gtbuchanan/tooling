#!/usr/bin/env sh
#MISE description="Run hk across all files (fixes locally, checks in CI)"
set -eu

# Like prek's `run`, apply fixes locally; keep CI a non-modifying gate.
cmd=fix
[ -z "${CI:-}" ] || cmd=check

# `hk <cmd> --all` runs each step's command via cmd.exe on Windows, whose
# 8191-char limit it overflows on large repos. HK_BATCH=1 turns on per-step
# batching in hk.pkl, so hk chunks files (~one batch per core) to sizes it
# keeps under the limit. Extra args forward to hk (e.g. -S <step>).
# See jdx/hk discussion #971: https://github.com/jdx/hk/discussions/971
HK_BATCH=1 hk "$cmd" --all "$@"
