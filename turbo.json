{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "mise.lock",
    "mise.toml",
    "pnpm-lock.yaml"
  ],
  "tasks": {
    "//#lint:eslint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!packages/*/**"
      ],
      "outputs": [
        "dist/.eslintcache",
        "dist/sarif/eslint.sarif"
      ]
    },
    "build": {
      "dependsOn": [
        "check",
        "compile",
        "pack",
        "test:slow",
        "test:e2e",
        "deploy:skills"
      ]
    },
    "build:ci": {
      "dependsOn": [
        "check",
        "compile",
        "pack"
      ]
    },
    "check": {
      "dependsOn": [
        "typecheck",
        "lint",
        "test:vitest:fast"
      ]
    },
    "compile": {
      "dependsOn": [
        "compile:ts",
        "compile:skills"
      ]
    },
    "compile:skills": {
      "inputs": [
        "skills/**"
      ],
      "outputs": [
        "dist/source/skills/**"
      ]
    },
    "compile:ts": {
      "dependsOn": [
        "^compile:ts"
      ],
      "inputs": [
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsconfig.build.json",
        "bin/**",
        "src/**",
        "tsconfig.build.json"
      ],
      "outputs": [
        "dist/source/**"
      ]
    },
    "coverage:codecov:upload": {
      "env": [
        "CI",
        "CODECOV_TOKEN"
      ],
      "inputs": [
        "dist/coverage/vitest/**/lcov.info"
      ],
      "outputs": [
        "dist/coverage/codecov/.uploaded"
      ]
    },
    "coverage:merge": {
      "dependsOn": [
        "coverage:vitest:merge"
      ]
    },
    "coverage:vitest:merge": {
      "dependsOn": [
        "test:vitest:fast",
        "test:vitest:slow"
      ],
      "inputs": [
        "dist/test-results/vitest/merge/blob-*.json"
      ],
      "outputs": [
        "dist/coverage/vitest/merged/**"
      ]
    },
    "deploy:skills": {
      "dependsOn": [
        "lint:eslint"
      ],
      "inputs": [
        "$TURBO_ROOT$/skills-npm.config.ts",
        "skills/**"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": [
        "lint:eslint",
        "//#lint:eslint"
      ]
    },
    "lint:eslint": {
      "dependsOn": [
        "typecheck:ts"
      ],
      "inputs": [
        "$TURBO_ROOT$/eslint.config.*",
        "bin/**",
        "src/**",
        "test/**",
        "e2e/**",
        "scripts/**",
        "skills/**",
        "eslint.config.*"
      ],
      "outputs": [
        "dist/.eslintcache",
        "dist/sarif/eslint.sarif"
      ]
    },
    "pack": {
      "dependsOn": [
        "pack:npm",
        "pack:pkl"
      ]
    },
    "pack:npm": {
      "dependsOn": [
        "compile:ts",
        "compile:skills"
      ],
      "inputs": [
        "$TURBO_ROOT$/LICENSE",
        "$TURBO_ROOT$/package.json",
        "LICENSE",
        "README.md",
        "dist/source/**",
        "!dist/source/LICENSE",
        "!dist/source/README.md",
        "!dist/source/package.json",
        "package.json"
      ],
      "outputs": [
        "dist/packages/npm/**",
        "dist/source/LICENSE",
        "dist/source/README.md",
        "dist/source/package.json"
      ]
    },
    "pack:pkl": {
      "dependsOn": [
        "typecheck:pkl"
      ],
      "inputs": [
        "*.pkl",
        "PklProject",
        "package.json"
      ],
      "outputs": [
        "dist/packages/pkl/**"
      ]
    },
    "test:e2e": {
      "dependsOn": [
        "test:vitest:e2e"
      ]
    },
    "test:slow": {
      "dependsOn": [
        "test:vitest:slow"
      ]
    },
    "test:vitest:e2e": {
      "dependsOn": [
        "pack",
        "^pack"
      ],
      "env": [
        "CI"
      ],
      "inputs": [
        "e2e/**",
        "vitest.config.e2e.*"
      ],
      "outputs": [
        "dist/test-results/vitest/blob-e2e.json"
      ]
    },
    "test:vitest:fast": {
      "dependsOn": [
        "^compile:ts"
      ],
      "env": [
        "CI"
      ],
      "inputs": [
        "bin/**",
        "src/**",
        "test/**",
        "scripts/**",
        "vitest.config.*",
        "!vitest.config.e2e.*"
      ],
      "outputs": [
        "dist/coverage/vitest/fast/**",
        "dist/test-results/vitest/merge/blob-fast.json"
      ]
    },
    "test:vitest:slow": {
      "dependsOn": [
        "^compile:ts"
      ],
      "env": [
        "CI"
      ],
      "inputs": [
        "bin/**",
        "src/**",
        "test/**",
        "scripts/**",
        "vitest.config.*",
        "!vitest.config.e2e.*"
      ],
      "outputs": [
        "dist/coverage/vitest/slow/**",
        "dist/test-results/vitest/merge/blob-slow.json"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "typecheck:ts",
        "typecheck:pkl"
      ]
    },
    "typecheck:pkl": {
      "inputs": [
        "*.pkl",
        "PklProject"
      ],
      "outputs": []
    },
    "typecheck:ts": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_ROOT$/tsconfig.base.json",
        "bin/**",
        "scripts/**",
        "src/**",
        "test/**",
        "e2e/**",
        "*.cjs",
        "*.cts",
        "*.js",
        "*.jsx",
        "*.mjs",
        "*.mts",
        "*.ts",
        "*.tsx",
        ".*.cjs",
        ".*.cts",
        ".*.js",
        ".*.jsx",
        ".*.mjs",
        ".*.mts",
        ".*.ts",
        ".*.tsx",
        "tsconfig.json",
        "tsconfig.*.json"
      ],
      "outputs": []
    }
  }
}
