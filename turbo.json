{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["build:ci", "test:slow", "test:e2e"]
    },
    "build:ci": {
      "dependsOn": ["check", "compile", "pack"]
    },
    "check": {
      "dependsOn": ["typecheck", "lint", "test:vitest:fast"]
    },
    "compile": {
      "dependsOn": ["compile:ts"]
    },
    "compile:ts": {
      "dependsOn": ["^compile:ts"],
      "inputs": ["bin/**", "src/**", "scripts/**", "tsconfig.json", "tsconfig.*.json"],
      "outputs": ["dist/source/**"]
    },
    "lint": {
      "dependsOn": ["lint:eslint", "lint:oxlint"]
    },
    "lint:eslint": {
      "dependsOn": ["typecheck:ts"],
      "inputs": [
        "$TURBO_ROOT$/eslint.config.*",
        "bin/**",
        "src/**",
        "test/**",
        "e2e/**",
        "scripts/**",
        "eslint.config.*"
      ],
      "outputs": ["dist/.eslintcache"]
    },
    "lint:oxlint": {
      "dependsOn": ["typecheck:ts"],
      "inputs": ["bin/**", "src/**", "test/**", "e2e/**", "scripts/**", "oxlint.config.*"],
      "outputs": []
    },
    "pack": {
      "dependsOn": ["pack:npm"]
    },
    "pack:npm": {
      "dependsOn": ["compile:ts"],
      "inputs": ["$TURBO_ROOT$/package.json", "dist/source/**", "package.json"],
      "outputs": ["dist/packages/npm/**", "dist/source/package.json"]
    },
    "test:e2e": {
      "dependsOn": ["test:vitest:e2e"]
    },
    "test:slow": {
      "dependsOn": ["test:vitest:slow"]
    },
    "test:vitest:e2e": {
      "dependsOn": ["pack", "^pack"],
      "env": ["CI"],
      "inputs": ["e2e/**", "vitest.config.e2e.*"],
      "outputs": []
    },
    "test:vitest:fast": {
      "dependsOn": ["^compile:ts"],
      "env": ["CI"],
      "inputs": ["bin/**", "src/**", "test/**", "scripts/**", "vitest.config.*"],
      "outputs": ["dist/coverage/vitest/**", "dist/test-results/vitest/**"]
    },
    "test:vitest:slow": {
      "dependsOn": ["test:vitest:fast", "^compile:ts"],
      "env": ["CI"],
      "inputs": ["bin/**", "src/**", "test/**", "scripts/**", "vitest.config.*"],
      "outputs": ["dist/coverage/vitest/**", "dist/test-results/vitest/**"]
    },
    "typecheck": {
      "dependsOn": ["typecheck:ts"]
    },
    "typecheck:ts": {
      "inputs": [
        "bin/**",
        "src/**",
        "test/**",
        "e2e/**",
        "scripts/**",
        "tsconfig.json",
        "tsconfig.*.json"
      ],
      "outputs": []
    }
  }
}
